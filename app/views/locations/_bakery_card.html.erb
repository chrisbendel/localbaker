<%= link_to storefront_path(store.slug), class: "card block decor-none" do %>
  <div class="group justify-between items-start">
    <div class="stack-sm">
      <h3 class="section-title"><%= store.name %></h3>
      <p class="text-muted"><%= store.location_display %></p>

      <% if distance.present? %>
        <p class="text-sm">
          <%= number_with_precision(distance, precision: 1) %> miles away
        </p>
      <% end %>

      <% upcoming_event = store.events.active_published.first %>
      <% if upcoming_event %>
        <p class="text-sm font-bold">
          Next pickup: <%= upcoming_event.pickup_at.strftime("%a, %b %-d at %l:%M %p") %>
        </p>
      <% end %>
    </div>

    <% if store.photo.attached? %>
       <%= image_tag store.photo, alt: store.name, class: "img-thumb", style: "width: 80px; height: 80px;" %>
    <% end %>
  </div>
<% end %>

<%= link_to storefront_path(store.slug), class: "card block decor-none" do %>
  <div class="group justify-between items-start">
    <div class="stack-sm">
      <div class="stack-sm">
        <h3><%= store.name %></h3>
        <small><%= store.location_display %></small>

        <% if distance.present? %>
          <small><%= number_with_precision(distance, precision: 1) %> miles away</small>
        <% end %>
      </div>

      <% if upcoming_event %>
        <div class="stack-sm">
          <p>Next Pickup: <strong><%= upcoming_event.pickup_starts_at.strftime("%A, %b %-d") %></strong></p>
          <small class="text-muted">Orders close <%= fuzzy_date(upcoming_event.orders_close_at) %></small>
        </div>
      <% end %>
    </div>

    <% if store.photo.attached? %>
       <%= image_tag store.photo, alt: store.name, class: "img-thumb-lg" %>
    <% end %>
  </div>
<% end %>

<% if links.any? %>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <% links.each_with_index do |link, index| %>
      <% if index > 0 %>
        <span class="sep" aria-hidden="true"></span>
      <% end %>

      <% if link[:path] %>
        <%= link_to link[:name], link[:path] %>
      <% else %>
        <span class="current"><%= link[:name] %></span>
      <% end %>
    <% end %>
  </nav>
<% end %>

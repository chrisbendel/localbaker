<header>
  <div class="flex items-center justify-between">
    <%= link_to root_path, class: "nav-logo" do %>
      <img src="/baguette.svg" height="28" alt="LocalBaker">
    <% end %>

    <nav class="group items-center group-lg">
      <% if authenticated? %>
        <% if (store = current_user.store)&.persisted? %>
          <%= link_to "Storefront", storefront_path(store.slug) %>
          <%= link_to "Bakery", store_path %>
        <% end %>

        <% upcoming_orders = current_user.orders
                                         .joins(:event)
                                         .where("events.pickup_at >= ?", Time.current)
                                         .includes(event: :store)
                                         .order("events.pickup_at ASC") %>
        <% if upcoming_orders.any? %>
          <%= link_to orders_path, class: "nav-icon nav-orders", aria: { label: "#{upcoming_orders.count} upcoming #{upcoming_orders.count == 1 ? 'order' : 'orders'}" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 01-8 0"/>
            </svg>
            <span class="nav-order-count"><%= upcoming_orders.count %></span>
          <% end %>
        <% end %>

        <%= link_to settings_account_path, class: "nav-icon", aria: { label: "Settings" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          </svg>
        <% end %>
      <% else %>
        <%= link_to "Sign in", new_session_path(return_to: request.fullpath) %>
      <% end %>
    </nav>
  </div>
</header>

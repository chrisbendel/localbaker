<header>
  <div class="group justify-between items-center">
    <%= link_to root_path, class: "nav-logo" do %>
      <img src="/baguette.svg" height="28" alt="LocalBaker">
    <% end %>

    <nav class="group items-center group-lg">
      <% if authenticated? %>
        <%# Remove Storefront/Manage text links as we use icons now %>

        <% upcoming_orders = current_user.orders
                                         .joins(:event)
                                         .where("events.pickup_at >= ?", Time.current)
                                         .includes(event: :store)
                                         .order("events.pickup_at ASC") %>
        <% if upcoming_orders.any? %>
          <%= link_to orders_path, class: "nav-icon nav-orders", aria: { label: "#{upcoming_orders.count} upcoming #{upcoming_orders.count == 1 ? 'order' : 'orders'}" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 01-8 0"/>
            </svg>
            <span class="nav-order-count"><%= upcoming_orders.count %></span>
          <% end %>
        <% end %>

        <% if current_user.store&.persisted? %>
          <%= link_to store_path, class: "nav-icon", aria: { label: "Bakery Management" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/>
              <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
              <path d="M15 22v-4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v4"/>
              <path d="M2 7h20"/>
              <path d="M22 7v3a2 2 0 0 1-2 2v0a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 16 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 12 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 8 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 4 12v0a2 2 0 0 1-2-2V7"/>
            </svg>
          <% end %>
        <% end %>

        <%= link_to settings_account_path, class: "nav-icon", aria: { label: "Account Settings" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          </svg>
        <% end %>
      <% else %>
        <%= link_to "Sign in", new_session_path(return_to: request.fullpath) %>
      <% end %>
    </nav>
  </div>
</header>

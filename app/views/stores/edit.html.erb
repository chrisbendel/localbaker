<% content_for :title, "#{@store.name} — Store Settings" %>

<div class="stack">
  <div class="group justify-between">
    <h3>Store Settings</h3>
    <p><%= link_to "Back to store", store_path %></p>
  </div>

  <div class="group justify-between items-center" data-controller="share" data-share-url-value="<%= @storefront_url %>">
    <div class="group items-center">
      <%= link_to @storefront_url, @storefront_url, target: "_blank", rel: "noopener", class: "text-sm text-muted" %>
      <button class="copy-btn" data-action="share#copy" aria-label="Copy store link">
        <svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
          <rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
        </svg>
        <svg class="icon-check" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </button>
    </div>
    <% if current_user.pro? %>
      <%= link_to "QR Poster", qr_store_path, target: "_blank", class: "button secondary small" %>
    <% else %>
      <%= link_to "QR Poster ↑ Pro", billing_upgrade_path, class: "button secondary small text-muted" %>
    <% end %>
  </div>

  <%= form_with model: @store, url: store_path do |f| %>
    <div>
      <%= f.label :name %>
      <%= f.text_field :name %>
    </div>

    <div>
      <%= f.label :slug, "Store URL" %>
      <%= f.text_field :slug, disabled: @store.active_orders? %>
      <% if @store.active_orders? %>
        <p>Slug cannot be changed while you have active orders.</p>
      <% end %>
    </div>

    <div>
      <%= f.label :description %>
      <%= f.text_area :description %>
    </div>

    <div>
      <%= f.label :address, "Store Address" %>
      <%= f.text_field :address, placeholder: "e.g. 123 Main St, Portland, OR 97201" %>
      <p class="text-muted text-sm">Your default pickup location. Customers will see this on event pages. Optional.</p>
    </div>

    <div data-controller="image-upload">
      <%= f.label :banner_image, "Store Banner" %>
      <% if @store.banner_image.attached? %>
        <%= image_tag @store.banner_image.variant(resize_to_limit: [1200, 800], format: :webp), class: "img-banner" %>
        <label>
          <%= f.check_box :remove_banner_image %> Remove current banner
        </label>
      <% end %>
      <div class="group items-center">
        <%= f.file_field :banner_image, data: { image_upload_target: "input", action: "change->image-upload#changed" } %>
        <button type="button" class="button secondary" data-image-upload-target="cancelButton" data-action="image-upload#cancel" style="display: none;">Cancel</button>
      </div>
    </div>

    <div>
      <%= f.submit "Save Changes", class: "button primary" %>
    </div>
  <% end %>

  <hr class="divider">

  <div class="stack-sm">
    <p class="text-sm font-bold text-danger">Danger Zone</p>
    <p class="text-muted text-sm">Deleting your store will permanently remove all events, products, and order history.</p>
    <div class="group">
      <%= button_to "Delete Store", store_path,
          method: :delete,
          class: "button danger",
          data: { turbo_confirm: "Are you sure? This will permanently delete your entire store and all its history. This cannot be undone." } %>
    </div>
  </div>
</div>
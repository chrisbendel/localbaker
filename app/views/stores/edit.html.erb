<% content_for :title, "#{@store.name} — Edit Store" %>

<div class="group justify-between">
  <h3>Edit Store</h3>
  <p><%= link_to "Back to store", store_path %></p>
</div>

<%= form_with model: @store, url: store_path do |f| %>
  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :slug, "Store URL" %>
    <%= f.text_field :slug, disabled: @store.active_orders? %>
    <% if @store.active_orders? %>
      <p>Slug cannot be changed while you have active orders.</p>
    <% end %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.label :address, "Store Address" %>
    <%= f.text_field :address, placeholder: "e.g. 123 Main St, Portland, OR 97201" %>
    <p class="text-muted text-sm">Your default pickup location. Customers will see this on event pages. Optional.</p>
  </div>

  <div data-controller="image-upload">
    <%= f.label :banner_image, "Store Banner" %>
    <% if @store.banner_image.attached? %>
      <div style="margin-bottom: var(--sp-sm);">
        <label>
          <%= f.check_box :remove_banner_image %> Remove current banner
        </label>
      </div>
    <% end %>
    <div class="group items-center">
      <%= f.file_field :banner_image, data: { image_upload_target: "input", action: "change->image-upload#changed" } %>
      <button type="button" class="button secondary" data-image-upload-target="cancelButton" data-action="image-upload#cancel" style="display: none;">Cancel</button>
    </div>
  </div>

  <div>
    <%= f.submit "Save Changes", class: "button primary" %>
  </div>
<% end %>

<hr class="divider">

<div class="stack-sm">
  <p class="text-sm font-bold text-danger">Danger Zone</p>
  <p class="text-muted text-sm">Deleting your store will permanently remove all events, products, and order history.</p>
  <div class="group">
    <%= button_to "Delete Store", store_path,
        method: :delete,
        class: "button danger",
        data: { turbo_confirm: "Are you sure? This will permanently delete your entire store and all its history. This cannot be undone." } %>
  </div>
</div>

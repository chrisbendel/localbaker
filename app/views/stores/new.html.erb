<% content_for :title, "Create Store" %>
<h1>Create Store</h1>

<%= form_with model: @store, url: store_path do |f| %>
  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :slug, "Store URL" %>
    <%= f.text_field :slug, placeholder: "my-bread-shop" %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <div data-controller="image-upload">
    <%= f.label :banner_image, "Store Banner" %>
    <div class="group items-center">
      <%= f.file_field :banner_image, data: { image_upload_target: "input", action: "change->image-upload#changed" } %>
      <button type="button" class="button small secondary" data-image-upload-target="cancelButton" data-action="image-upload#cancel" style="display: none;">Cancel</button>
    </div>
  </div>

  <div>
    <%= f.submit "Create Store", class: "button primary" %>
  </div>
<% end %>

<% content_for :title, "#{@store.name} — All Events" %>

<div class="group justify-between items-center">
  <h3>Events</h4>
  <%= link_to "+ New Event", new_store_event_path, class: "button primary" %>
</div>

<div class="stack-lg">
  <%# 1. Active Events (Taking Orders + Prep) %>
  <% active_events = @events.reject(&:past?).reject(&:draft?) %>
  <% if active_events.any? %>
    <div class="stack-sm">
      <h4 class="section-title">Active Bakes</h4>
      <table class="responsive-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Orders Close</th>
            <th>Pickup</th>
          </tr>
        </thead>
        <tbody>
          <% active_events.each do |event| %>
            <tr id="<%= dom_id(event) %>">
              <td data-label="Name">
                <%= link_to event.name, event_path(event), class: "font-bold" %>
              </td>
              <td data-label="Orders Close">
                <% if event.orders_close_at.present? %>
                  <%= nice_date(event.orders_close_at) %>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td data-label="Pickup"><%= nice_date(event.pickup_at) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <%# 2. Draft Events %>
  <% draft_events = @events.select(&:draft?) %>
  <% if draft_events.any? %>
    <div class="stack-sm">
      <h4 class="section-title">Drafts</h4>
      <table class="responsive-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Orders Close</th>
            <th>Pickup</th>
          </tr>
        </thead>
        <tbody>
          <% draft_events.each do |event| %>
            <tr id="<%= dom_id(event) %>">
              <td data-label="Name">
                <%= link_to event.name, event_path(event), class: "font-bold" %>
              </td>
              <td data-label="Orders Close"><span class="text-muted">—</span></td>
              <td data-label="Pickup"><%= nice_date(event.pickup_at) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <%# 3. Past Events %>
  <% past_events = @events.select(&:past?) %>
  <% if past_events.any? %>
    <div class="stack-sm">
      <h4 class="section-title">Past Bakes</h4>
      <table class="responsive-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Orders Close</th>
            <th>Pickup</th>
          </tr>
        </thead>
        <tbody>
          <% past_events.each do |event| %>
            <tr id="<%= dom_id(event) %>">
              <td data-label="Name">
                <%= link_to event.name, event_path(event), class: "font-bold" %>
              </td>
              <td data-label="Orders Close"><%= nice_date(event.orders_close_at) %></td>
              <td data-label="Pickup"><%= nice_date(event.pickup_at) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <% if @events.empty? %>
    <div class="empty-state stack-sm">
      <p class="text-muted">Events are how you sell. Create one to set a pickup date, add products, and start taking orders.</p>
      <%= link_to "Create your first event", new_store_event_path, class: "button primary" %>
    </div>
  <% end %>
</div>

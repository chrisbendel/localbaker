<% content_for :title, @event.name %>

<%= render_breadcrumbs([
  { name: @store.name, path: store_path },
  { name: @event.name }
]) %>

<div class="group justify-between items-start">
  <div class="stack-sm">
    <div class="group items-center">
      <h2><%= @event.name %></h2>
      <% if @event.draft? %>
        <span class="badge draft">Draft</span>
      <% end %>
    </div>
  </div>

  <div class="group items-center">
    <% if current_user == @store.user %>
      <%= button_to "Duplicate", duplicate_event_path(@event),
          method: :post,
          class: "button secondary",
          data: { turbo_confirm: "Duplicate this event? All products and images will be copied to a new draft." } %>
      <%= link_to "Edit Event", edit_event_path(@event), class: "button secondary" %>
    <% end %>
  </div>
</div>

<div class="stack-sm" style="margin-top: var(--sp-sm);">
  <p class="text-muted">
    Orders close <%= nice_date(@event.orders_close_at) %> &middot;
    Pickup <%= pickup_datetime(@event.pickup_at) %>
  </p>
  <%= render "application/address_line", model: @event, show_full: true %>
  <% if @event.repeat_interval.present? && !@event.no_repeat? %>
    <p class="text-success text-sm font-bold">
      Repeats <%= @event.repeat_interval.humanize %>
    </p>
  <% end %>
</div>

<% if @event.description.present? %>
  <p style="margin-top: var(--sp-md);"><%= @event.description %></p>
<% end %>

<hr class="divider">

<div class="group justify-between items-baseline">
  <h3>Products</h3>
  <% if current_user == @store.user %>
    <%= link_to "+ Add Product", new_event_event_product_path(@event), class: "button primary" %>
  <% end %>
</div>

<% if @event.event_products.any? %>
  <table class="responsive-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Qty</th>
        <th>Price</th>
        <% if current_user == @store.user %>
          <th></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% @event.event_products.each do |product| %>
        <tr>
          <td data-label="Name">
            <div class="group items-center" style="gap: var(--sp-sm);">
              <% if product.image.attached? %>
                <%= image_tag product.image.variant(resize_to_limit: [40, 40], format: :webp), class: "img-thumb" %>
              <% end %>
              <strong><%= product.name %></strong>
            </div>
          </td>
          <td data-label="Qty"><%= product.quantity %></td>
          <td data-label="Price"><%= product.price_formatted %></td>
          <% if current_user == @store.user %>
            <td class="group justify-end items-center">
              <%= link_to "Edit", edit_event_product_path(product) %>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty-state stack-sm">
    <p class="text-muted">No products yet. Add at least one product before you can publish this event.</p>
    <% if current_user == @store.user %>
      <%= link_to "Add a product", new_event_event_product_path(@event), class: "button primary" %>
    <% end %>
  </div>
<% end %>

<% if @event.draft? && current_user == @store.user && @event.event_products.present? %>
  <div class="nudge" style="margin-top: var(--sp-md);">
    <div class="group justify-between items-center">
      <span>Ready to go? Publishing will notify all subscribers.</span>
      <%= button_to "Publish Event", publish_event_path(@event), method: :post,
          class: "button primary",
          data: { turbo_confirm: "Are you sure? This will email all subscribers." } %>
    </div>
  </div>
<% end %>

<% if @event.published? %>
  <hr class="divider">

  <div class="stack-sm">
    <div class="group justify-between items-baseline">
      <h3>Orders <% if @orders.any? %><span class="text-muted text-sm">(<%= @orders.count %>)</span><% end %></h3>
      <% if @orders.any? %>
        <%= link_to "Prep List", prep_event_path(@event), target: "_blank", class: "button secondary" %>
      <% end %>
    </div>

    <% if @orders.any? %>
      <div class="panel stack-sm" style="margin-bottom: var(--sp-md);">
        <p class="text-sm font-bold">Prep summary</p>
        <% @event.event_products.each do |product| %>
          <div class="group justify-between text-sm">
            <span><%= product.name %></span>
            <span><strong><%= product.sold %></strong> / <%= product.quantity %></span>
          </div>
        <% end %>
      </div>

      <table class="responsive-table">
        <thead>
          <tr>
            <th>Customer</th>
            <th>Items</th>
            <th>Total</th>
            <th>Placed</th>
          </tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr>
              <td data-label="Customer"><%= order.user.email %></td>
              <td data-label="Items">
                <% order.order_items.each do |item| %>
                  <div class="text-sm"><%= item.event_product.name %> &times; <%= item.quantity %></div>
                <% end %>
              </td>
              <td data-label="Total"><%= number_to_currency(order.total_price) %></td>
              <td data-label="Placed"><%= nice_date(order.created_at) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="empty-state stack-sm">
        <p class="text-muted">No orders yet. Share your store link so customers can place orders.</p>
      </div>
    <% end %>
  </div>
<% end %>

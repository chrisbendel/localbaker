<%= render_breadcrumbs([
  { name: @store.name, path: store_path },
  { name: @event.name, path: event_path(@event) },
  { name: "Edit" }
]) %>

<h1>Edit Event</h1>

<%= form_with model: [@event], local: true do |form| %>
  <div>
    <%= form.label :name %>
    <%= form.text_field :name, required: true %>
  </div>

  <div>
    <%= form.label :description %>
    <%= form.text_area :description %>
  </div>

  <div>
    <%= form.label :pickup_address, "Pickup Location" %>
    <%= form.text_field :pickup_address, placeholder: "e.g. The Climbing Gym, 456 Oak Ave, Portland, OR" %>
    <p class="text-muted text-sm">Where customers should pick up their order. Leave blank to use your store's default address.</p>
  </div>

  <div>
    <%= form.label :orders_close_at, "Orders close at" %>
    <%= form.date_field :orders_close_at, required: true, min: Date.current %>
  </div>

  <div>
    <%= form.label :pickup_at, "Pickup date" %>
    <%= form.date_field :pickup_at, required: true, min: Date.current %>
  </div>

  <div>
    <%= form.label :repeat_interval, "Repeat cadence" %>
    <%= form.select :repeat_interval, Event.repeat_intervals.keys.map { |k| [k.gsub("_", " ").humanize, k] } %>
    <p class="text-muted text-sm">When published, a new draft will be created automatically for the next bake.</p>
  </div>

  <div style="margin-top: var(--sp-md);">
    <%= form.submit "Save Changes", class: "button primary" %>
  </div>
<% end %>

<hr class="divider">

<div class="stack-sm">
  <p class="text-sm font-bold text-danger">Danger Zone</p>
  <% if @event.orders.any? %>
    <p class="text-muted text-sm">This event has <%= pluralize(@event.orders.count, "order") %>. Deleting it will also delete all associated orders.</p>
  <% end %>
  <div class="group">
    <%= button_to "Delete Event", event_path(@event), 
        method: :delete, 
        class: "button danger",
        data: { turbo_confirm: "Are you sure? This will permanently delete the event and all associated orders." } %>
  </div>
</div>


<h3>New Event</h3>

<%= form_with model: [@store, @event], local: true do |form| %>
  <div>
    <%= form.label :name %>
    <%= form.text_field :name, required: true %>
  </div>

  <div>
    <%= form.label :description %>
    <%= form.text_area :description %>
  </div>

  <div>
    <%= form.label :pickup_address, "Pickup Location" %>
    <%= form.text_field :pickup_address, placeholder: "e.g. The Climbing Gym, 456 Oak Ave, Portland, OR" %>
    <p class="field-hint">Where customers should pick up their order. Leave blank to use your store's default address.</p>
  </div>

  <% if current_user.pro? %>
    <div>
      <%= form.label :delivery_enabled, "Allow Delivery" %>
      <%= form.check_box :delivery_enabled %>
      <p class="field-hint">Let customers enter a delivery address instead of picking up. Both pickup and delivery can be offered.</p>
    </div>
  <% else %>
    <div class="nudge">
      <p>Delivery is a Pro feature. <%= link_to "Upgrade to Pro", billing_upgrade_path %> to offer delivery on your events.</p>
    </div>
  <% end %>

  <div>
    <%= form.label :orders_close_at, "Orders close at" %>
    <%= form.date_field :orders_close_at, required: true, min: Date.current %>
  </div>

  <div>
    <%= form.label :pickup_at, "Pickup date" %>
    <%= form.date_field :pickup_at, required: true, min: Date.current %>
  </div>

  <div>
    <%= form.label :repeat_interval, "Repeat cadence" %>
    <%= form.select :repeat_interval, Event.repeat_intervals.keys.map { |k| [k.gsub("_", " ").humanize, k] } %>
    <p class="field-hint">When published, a new draft will be created automatically for the next bake.</p>
  </div>

  <div style="margin-top: var(--sp-md);">
    <%= form.submit "Create Event", class: "button primary" %>
  </div>
<% end %>

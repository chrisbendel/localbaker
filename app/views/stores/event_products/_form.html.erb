<%= form_with model: event_product.new_record? ? [event, event_product] : event_product, local: true do |f| %>
  <% if event_product.errors.any? %>
    <div class="panel text-danger">
      Please fix the errors below before saving.
    </div>
  <% end %>

  <div>
    <%= f.label :name %>
    <%= f.text_field :name, required: true %>
    <% if event_product.errors[:name].any? %>
      <p class="field-error"><%= event_product.errors[:name].join(", ") %></p>
    <% end %>
  </div>

  <div>
    <%= f.label :quantity %>
    <%= f.number_field :quantity, required: true, min: 0 %>
    <% if event_product.errors[:quantity].any? %>
      <p class="field-error"><%= event_product.errors[:quantity].join(", ") %></p>
    <% end %>
  </div>

  <div>
    <%= f.label :price, "Price ($)" %>
    <%= f.number_field :price, step: 0.01, min: 0, required: true %>
    <% if event_product.errors[:price].any? %>
      <p class="field-error"><%= event_product.errors[:price].join(", ") %></p>
    <% end %>
  </div>

  <div data-controller="image-upload">
    <%= f.label :image %>
    <% if event_product.image.attached? %>
      <div style="margin-bottom: var(--sp-sm);">
        <%= image_tag event_product.image.variant(resize_to_limit: [200, 200], format: :webp), style: "max-width: 200px; display: block; margin-bottom: 4px;" %>
        <label>
          <%= f.check_box :remove_image %> Remove current image
        </label>
      </div>
    <% end %>
    <div class="group items-center">
      <%= f.file_field :image, accept: "image/*", data: { image_upload_target: "input", action: "change->image-upload#changed" } %>
      <button type="button" class="button secondary" data-image-upload-target="cancelButton" data-action="image-upload#cancel" style="display: none;">Cancel</button>
    </div>
  </div>

  <div>
    <%= f.submit event_product.new_record? ? "Add Product" : "Save Changes", class: "button primary" %>
  </div>
<% end %>

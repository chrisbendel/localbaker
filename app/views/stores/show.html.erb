<% content_for :title, "#{@store.name} — Store" %>
<div class="stack">
  <div class="group justify-between items-start">
    <div class="stack-sm">
      <h2><%= @store.name %></h2>
      <p class="text-muted text-sm">localbaker.app/shop/<%= @store.slug %></p>
    </div>

    <div class="group items-center">
      <%= link_to "Edit Store", edit_store_path, class: "button small secondary" %>
    </div>
  </div>

  <% if @store.description.present? %>
    <pre><%= @store.description %></pre>
  <% end %>


  <hr class="divider">

  <div class="group justify-between items-center">
    <h3>Events</h3>
    <%= link_to "+ New Event", new_store_event_path, class: "button primary" %>
  </div>

  <% if @store.events.any? %>
    <div class="stack">
      <% upcoming = @store.events.where("pickup_at >= ?", Date.current).order(pickup_at: :asc) %>
      <% past = @store.events.where("pickup_at < ?", Date.current).order(pickup_at: :desc) %>

      <% if upcoming.any? %>
        <div class="stack-sm">
          <h4 class="text-muted">Upcoming</h4>
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Orders close</th>
                <th>Pickup</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% upcoming.each do |event| %>
                <tr>
                  <td>
                    <%= link_to event.name, event_path(event) %>
                    <% if event.draft? %>
                      <span class="badge draft">Draft</span>
                    <% end %>
                  </td>
                  <td><%= nice_date(event.orders_close_at) %></td>
                  <td><%= nice_date(event.pickup_at) %></td>
                  <td>
                    <div class="group justify-end">
                      <%= link_to "Manage", event_path(event), class: "button small secondary" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>

      <% if past.any? %>
        <details>
          <summary class="text-muted text-sm">Past Events (<%= past.count %>)</summary>
          <div class="stack-sm" style="margin-top: var(--sp-sm);">
            <table class="text-sm">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Pickup</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% past.each do |event| %>
                  <tr>
                    <td class="text-muted"><%= link_to event.name, event_path(event) %></td>
                    <td class="text-muted"><%= nice_date(event.pickup_at) %></td>
                    <td>
                      <div class="group justify-end">
                        <%= button_to "Reuse", duplicate_event_path(event), params: { interval: 1 }, class: "button small secondary" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </details>
      <% end %>
    </div>
  <% else %>
    <div class="nudge">
      <span>
        Your store is set up! Next,
        <%= link_to "create your first event", new_store_event_path %>
        to start accepting orders.
      </span>
    </div>
  <% end %>
</div>

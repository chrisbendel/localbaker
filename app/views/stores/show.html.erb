<% content_for :title, "#{@store.name} — Store" %>
<div class="stack">
  <div class="group justify-between items-center">
    <h2><%= @store.name %></h2>
    <div class="group items-center">
      <%= link_to "Storefront", storefront_path(@store.slug), class: "button secondary" %>
      <%= link_to "Edit Store", edit_store_path, class: "button secondary" %>
    </div>
  </div>
  <div></div>

  <div class="group justify-between items-center">
    <h3>Events</h3>
    <%= link_to "+ New Event", new_store_event_path, class: "button primary" %>
  </div>

  <% if @drafts.any? || @upcoming.any? || @past.any? %>
    <div class="stack">

      <% if @drafts.any? %>
        <div class="stack-sm">
          <h4 class="text-muted">Drafts</h4>
          <% @drafts.each do |event| %>
            <%= link_to event_path(event), class: "card" do %>
              <div class="group justify-between items-center">
                <strong><%= event.name %></strong>
                <span class="badge draft">Draft</span>
              </div>
              <p class="text-muted text-sm">
                Pickup <%= nice_date(event.pickup_at) %> &middot; Orders close <%= nice_date(event.orders_close_at) %>
              </p>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <% if @upcoming.any? %>
        <div class="stack-sm">
          <h4 class="text-muted">Upcoming</h4>
          <% @upcoming.each do |event| %>
            <%= link_to event_path(event), class: "card" do %>
              <strong><%= event.name %></strong>
              <p class="text-muted text-sm">
                Pickup <%= nice_date(event.pickup_at) %> &middot; Orders close <%= nice_date(event.orders_close_at) %>
              </p>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <% if @past.any? %>
        <details>
          <summary class="text-muted text-sm">Past Events (<%= @past.count %>)</summary>
          <div class="stack-sm" style="margin-top: var(--sp-sm);">
            <% @past.each do |event| %>
              <div class="group justify-between items-center">
                <%= link_to event.name, event_path(event), class: "text-sm font-bold" %>
                <div class="group items-center">
                  <span class="text-muted text-sm"><%= nice_date(event.pickup_at) %></span>
                  <%= button_to "Reuse", duplicate_event_path(event), class: "button secondary",
                      data: { turbo_confirm: "Duplicate this event? All products and images will be copied to a new draft." } %>
                </div>
              </div>
            <% end %>
          </div>
        </details>
      <% end %>

    </div>
  <% else %>
    <div class="nudge">
      <span>
        Your store is set up! Next,
        <%= link_to "create your first event", new_store_event_path %>
        to start accepting orders.
      </span>
    </div>
  <% end %>

  <% if @orders.any? %>
    <hr class="divider">

    <section class="stack">
      <h3>Your Orders</h3>
      <div class="stack-sm">
        <% @orders.each do |order| %>
          <%= link_to storefront_event_path(order.event.store.slug, order.event), class: "card" do %>
            <div class="group justify-between items-baseline">
              <strong><%= order.event.store.name %></strong>
              <span class="text-muted text-sm"><%= number_to_currency(order.total_price) %></span>
            </div>
            <p class="text-muted text-sm">
              <%= order.event.name %> &middot; Pickup <%= nice_date(order.event.pickup_at) %>
            </p>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>

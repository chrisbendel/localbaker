<% content_for :title, "Upgrade Successful" %>

<div class="stack-lg">
  <div class="panel stack">
    <h2>Upgrade Successful</h2>
    <p>Welcome to Pro! Your subscription is now active and you have unlimited access to all Pro features.</p>
  </div>

  <div class="card stack-sm">
    <h3>Pro Features Unlocked</h3>
    <ul class="stack-sm">
      <li>Unlimited active events (instead of <%= User::FREE_EVENT_LIMIT %>)</li>
      <li>Order confirmation emails sent to customers</li>
      <li>Event notifications sent to followers</li>
      <li>Pickup reminder emails (24 hours before pickup)</li>
      <li>Delivery orders with geographic zone restrictions</li>
    </ul>
  </div>

  <div class="group">
    <%= link_to "Back to Dashboard", dashboard_store_path, class: "button primary" %>
    <%= button_to "Manage Subscription", billing_portal_path, method: :post, class: "button", data: { turbo: false } %>
  </div>
</div>

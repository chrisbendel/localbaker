<% content_for :title, "Plans" %>

<div class="stack-lg">
  <h2>Plans</h2>

  <div class="stack">
    <div class="card stack-sm">
      <div class="group justify-between items-baseline">
        <h3>Free</h3>
        <% if current_user.free? %><span class="badge secondary">Current plan</span><% end %>
      </div>
      <ul class="stack-sm">
        <li><%= User::FREE_EVENT_LIMIT %> active events</li>
        <li>Order management & fulfillment</li>
        <li>QR code posters</li>
        <li>Pickup-only orders</li>
      </ul>
    </div>

    <div class="card stack-sm">
      <div class="group justify-between items-baseline">
        <h3>Pro</h3>
        <% if current_user.pro? %><span class="badge">Current plan</span><% end %>
      </div>
      <p>Everything in Free, plus:</p>
      <ul class="stack-sm">
        <li>Unlimited active events</li>
        <li>Delivery orders with zone restrictions</li>
        <li>Order confirmation emails to customers</li>
        <li>Event notifications to followers</li>
        <li>Pickup reminder emails (24h before)</li>
      </ul>
      <% if current_user.free? %>
        <div class="group">
          <%= button_to "Upgrade to Pro · $9/month", billing_checkout_path, method: :post, class: "button primary", data: { turbo: false } %>
        </div>
      <% end %>
    </div>
  </div>
</div>

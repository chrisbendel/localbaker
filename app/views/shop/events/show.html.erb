<% content_for :title, "#{@event.name} — #{@store.name} | Order bread near me" %>

<% og_description = @event.description.present? ? @event.description : "Order bread and baked goods for pick up from #{@store.name}, your local bakery, on #{pickup_datetime(@event.pickup_starts_at)}." %>
<% content_for(:meta_description, og_description) %>

<% if @store.cover_photo %>
  <% content_for(:og_image, url_for(@store.cover_photo)) %>
<% else %>
  <% content_for(:og_image, root_url.chomp("/") + "/baguette-solid.png") %>
<% end %>

<div class="stack-lg">
  <header class="stack-sm">
    <div class="group justify-between items-baseline">
      <%= link_to "← #{@store.name}", shop_path(@store.slug), class: "store-name-link text-muted" %>
    </div>

    <div class="stack-sm">
      <h1><%= @event.name %></h1>

      <% if @event.description.present? %>
        <p><%= @event.description %></p>
      <% end %>

      <div class="stack-sm">
        <div class="group-sm items-center text-muted">
          <small>Pick up <%= pickup_window(@event) %></small>
        </div>

        <div class="group-sm items-center text-muted">
          <small><%= event_orders_deadline(@event) %></small>
        </div>

        <% if @event.address.present? %>
          <div class="group-sm items-center text-muted">
            <small><%= link_to @event.address, google_maps_url(@event.address), target: "_blank", rel: "noopener noreferrer" %></small>
          </div>
        <% end %>
      </div>
    </div>
  </header>

  <%# Saved-order status banner — shown when customer has an order. %>
  <% if @order %>
    <%= render "shop/order_summary", order: @order, store: @store, event: @event %>
  <% end %>

  <% if @event.orders_closed? && !@order %>
    <div class="nudge">
      Orders for this bake have closed.
    </div>
  <% end %>

  <% if authenticated? && @event.orders_open? %>
    <%# Order form — pre-filled if order exists, blank otherwise. %>
    <%= render "shop/order_form", store: @store, event: @event, products: @products, order: @order %>
  <% elsif !authenticated? && @event.orders_open? %>
    <div class="panel stack-sm">
      <h3>Ready to order?</h3>
      <p><small>Sign in with an email link. No password.</small></p>
      <div>
        <%= link_to "Sign in to order", new_session_path(return_to: request.fullpath), class: "button primary" %>
      </div>
    </div>

    <section class="stack">
      <h4>Products</h4>
      <ul class="product-list stack-sm">
        <% @products.each do |product| %>
          <li class="product-row group justify-between items-center<%= ' sold-out' unless product.available? %>">
            <div class="group items-center">
              <% if product.image.attached? %>
                <%= image_tag product.image.variant(resize_to_limit: [60, 60], format: :webp), class: "img-thumb-lg" %>
              <% end %>
              <div class="stack-sm">
                <strong><%= product.name %></strong>
                <small class="text-muted">
                  <%= product.price_formatted %>
                  <% if product.available? %>
                    &middot; <%= product.remaining %> left
                  <% else %>
                    &middot; Sold out
                  <% end %>
                </small>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>
</div>

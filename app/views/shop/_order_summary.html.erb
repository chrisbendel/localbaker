<aside class="panel stack-sm">
  <div class="group justify-between items-baseline">
    <strong>Your order</strong>
    <strong><%= number_to_currency(order.total_price) %></strong>
  </div>

  <ul class="order-items stack-sm">
    <% order.order_items.includes(:event_product).each do |item| %>
      <li class="group justify-between">
        <span><%= item.event_product.name %></span>
        <small>×<%= item.quantity %></small>
      </li>
    <% end %>
  </ul>

  <div class="order-summary-pickup">
    <p><small>Pickup <%= fuzzy_date(event.pickup_starts_at) %> &middot; <%= pickup_time(event.pickup_starts_at) %>–<%= pickup_time(event.pickup_ends_at) %></small></p>
  </div>

  <% if order.delivery_address.present? %>
    <p><small><strong>Delivery:</strong> <%= order.delivery_address %></small></p>
  <% end %>

  <% if order.notes.present? %>
    <p><small><strong>Note:</strong> <%= order.notes %></small></p>
  <% end %>

  <div class="group-sm items-center">
    <small><%= link_to "Add to Google Calendar →", google_calendar_url(event), target: "_blank", rel: "noopener noreferrer" %></small>
    <% if event.orders_open? %>
      <small>&middot;</small>
      <small><%= button_to "Cancel order", shop_event_order_path(store.slug, event), method: :delete,
          class: "button-link text-muted",
          form: { data: { turbo_confirm: "Cancel your entire order? This cannot be undone." } } %></small>
    <% end %>
  </div>

  <% if store.venmo_handle.present? || store.paypal_url.present? %>
    <div class="stack-sm order-summary-payment">
      <h4>Payment</h4>
      <div class="group">
        <% if store.venmo_handle.present? %>
          <%= link_to store.venmo_url, target: "_blank", rel: "noopener noreferrer" do %>
            Venmo (<%= store.venmo_handle %>)
          <% end %>
        <% end %>

        <% if store.paypal_url.present? %>
          <%= link_to store.paypal_url, target: "_blank", rel: "noopener noreferrer" do %>
            PayPal
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</aside>

<% content_for :title, "Dashboard" %>

<% if @user.store || @orders.any? %>
  <div class="stack-lg">

    <% if @user.store %>
      <section class="stack">
        <div class="group justify-between items-baseline">
          <h3>Your Store</h3>
          <div class="group">
            <%= link_to "Storefront", storefront_path(@user.store.slug) %>
            <%= link_to "Manage", store_path %>
          </div>
        </div>

        <% if @user.store.events.published.any? %>
          <table>
            <thead>
              <tr>
                <th>Event</th>
                <th>Orders Close</th>
                <th>Pickup</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @user.store.events.published.each do |event| %>
                <tr>
                  <td><%= event.name %></td>
                  <td><%= nice_date(event.orders_close_at) %></td>
                  <td><%= pickup_datetime(event.pickup_at) %></td>
                  <td><%= link_to "Manage", event_path(event) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="nudge">
            <span>
              No active events.
              <%= link_to "Create one", new_store_event_path %> to start taking orders.
            </span>
          </div>
        <% end %>
      </section>
    <% end %>

    <% if @orders.any? %>
      <section class="stack">
        <h3>Your Orders</h3>
        <table class="responsive-table">
          <thead>
            <tr>
              <th>Store</th>
              <th>Event</th>
              <th>Pickup Date</th>
              <th>Total</th>
              <th>Placed</th>
            </tr>
          </thead>
          <tbody>
            <% @orders.each do |order| %>
              <tr>
                <td data-label="Store">
                  <%= link_to order.event.store.name, storefront_path(order.event.store.slug) %>
                </td>
                <td data-label="Event"><%= order.event.name %></td>
                <td data-label="Pickup Date"><%= pickup_datetime(order.event.pickup_at) %></td>
                <td data-label="Total"><%= number_to_currency(order.total_price) %></td>
                <td data-label="Placed"><%= nice_date(order.created_at) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </section>
    <% end %>

  </div>
<% else %>
  <div class="empty-state stack-sm">
    <p>This is your dashboard. You'll see orders you've placed and manage your bakery from here.</p>
    <p class="text-muted">Want to sell your own bread?</p>
    <%= link_to "Create your Store", new_store_path %>
  </div>
<% end %>

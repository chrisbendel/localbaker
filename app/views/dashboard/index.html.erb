<% content_for :title, "Dashboard" %>

<% if @user.store || @orders.any? %>
  <div class="stack-lg">

    <% if @user.store %>
      <section class="stack">
        <div class="group justify-between items-baseline">
          <h3>Events</h3>
          <%= link_to "+ New Event", new_store_event_path, class: "button primary" %>
        </div>

        <% events = @user.store.events.order(pickup_at: :desc) %>
        <% if events.any? %>
          <div class="stack-sm">
            <% events.each do |event| %>
              <%= link_to event_path(event), class: "card" do %>
                <div class="group justify-between items-center">
                  <strong><%= event.name %></strong>
                  <% if event.draft? %>
                    <span class="badge draft">Draft</span>
                  <% end %>
                </div>
                <p class="text-muted text-sm">
                  Pickup <%= nice_date(event.pickup_at) %> &middot; Orders close <%= nice_date(event.orders_close_at) %>
                </p>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="nudge">
            <span>
              No events yet.
              <%= link_to "Create one", new_store_event_path %> to start taking orders.
            </span>
          </div>
        <% end %>
      </section>
    <% end %>

    <% if @orders.any? %>
      <section class="stack">
        <h3>Your Orders</h3>
        <div class="stack-sm">
          <% @orders.each do |order| %>
            <%= link_to storefront_event_path(order.event.store.slug, order.event), class: "card" do %>
              <div class="group justify-between items-baseline">
                <strong><%= order.event.store.name %></strong>
                <span class="text-muted text-sm"><%= number_to_currency(order.total_price) %></span>
              </div>
              <p class="text-muted text-sm">
                <%= order.event.name %> &middot; Pickup <%= nice_date(order.event.pickup_at) %>
              </p>
            <% end %>
          <% end %>
        </div>
      </section>
    <% end %>

  </div>
<% else %>
  <div class="empty-state stack-sm">
    <p>This is your dashboard. You'll see orders you've placed and manage your bakery from here.</p>
    <p class="text-muted">Want to sell your own bread?</p>
    <%= link_to "Create your Store", new_store_path %>
  </div>
<% end %>

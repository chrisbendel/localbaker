<% content_for :title, "Create Store" %>
<h1>Create Store</h1>

<%= form_with model: @store, url: dashboard_store_path do |f| %>
  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :slug, "Store URL" %>
    <%= f.text_field :slug, placeholder: "my-bread-shop" %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.submit "Create Store", class: "button primary" %>
  </div>
<% end %>

<% content_for :title, "Payment Options — Baker Portal" %>

<div class="stack">
  <div class="group justify-between items-center">
    <h3>Payment Options</h3>
  </div>

  <p>Help customers find your preferred payment methods. LocalBaker handles orders, but payments happen directly between you and your customers.</p>

  <%= form_with model: @store, url: dashboard_payments_path do |f| %>
    <div >
      <%= f.label :venmo_handle, "Venmo Handle" %>
      <%= f.text_field :venmo_handle, placeholder: "@yourhandle" %>
    </div>

    <div>
      <%= f.label :paypal_url, "PayPal.me Link" %>
      <%= f.text_field :paypal_url, placeholder: "https://paypal.me/yourname" %>
    </div>

    <div>
      <%= f.submit "Save Changes", class: "button primary" %>
    </div>
  <% end %>
</div>

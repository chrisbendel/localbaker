<% content_for :title, "Orders — #{@event.name}" %>

<div class="stack-sm">
  <small><%= link_to "← #{@event.name}", event_path(@event) %></small>
  <h2>Orders</h2>
  <% if @orders.any? %>
    <small class="text-muted">
      <%= number_to_currency(@orders.sum(&:total_price)) %> across <%= pluralize(@orders.count, "order") %>
      &middot;
      <%= @orders.sum { |o| o.order_items.sum(&:quantity) } %> items
    </small>

    <div class="group items-center">
      <%= link_to "Pickup Sheet", pickup_sheet_event_path(@event), target: "_blank", class: "button" %>
      <small><%= link_to "Export CSV →", export_orders_event_path(@event) %></small>
    </div>
  <% end %>
</div>

<% if @orders.any? %>
  <hr class="divider">

  <div class="stack">
    <% @orders.each do |order| %>
      <article class="order-card stack-sm">
        <header class="group justify-between items-baseline">
          <strong><%= mail_to order.user.email, order.user.email %></strong>
          <div class="group-sm items-baseline">
            <strong><%= number_to_currency(order.total_price) %></strong>
            <small class="text-muted" title="<%= order.created_at.strftime('%Y-%m-%d %H:%M') %>"><%= nice_date(order.created_at) %></small>
          </div>
        </header>

        <ul class="order-card-items">
          <% order.order_items.each do |item| %>
            <li><%= item.quantity %> &times; <%= item.event_product.name %></li>
          <% end %>
        </ul>

        <% if order.notes.present? %>
          <div class="order-card-note">
            <strong>Note:</strong> <%= order.notes %>
          </div>
        <% end %>

        <% if order.delivery_address.present? %>
          <div class="order-card-delivery text-muted">
            <small><strong>Delivery:</strong> <%= order.delivery_address %></small>
          </div>
        <% end %>

        <footer class="group items-center">
          <%= button_to order.paid? ? "Paid ✓" : "Mark paid",
                dashboard_order_path(order),
                method: :patch,
                params: {order: {paid: order.paid? ? "0" : "1"}},
                class: "button secondary small",
                title: order.paid? ? "Click to undo" : "Record payment received" %>
          <%= button_to order.picked_up? ? "Picked up ✓" : "Mark picked up",
                dashboard_order_path(order),
                method: :patch,
                params: {order: {picked_up: order.picked_up? ? "0" : "1"}},
                class: "button secondary small",
                title: order.picked_up? ? "Click to undo" : "Record order handed off" %>
        </footer>
      </article>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <p>No orders yet. Share your shop link so customers can place orders.</p>
  </div>
<% end %>

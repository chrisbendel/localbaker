<% content_for :title, "Orders — #{@event.name}" %>

<div class="stack-sm">
  <small><%= link_to "← #{@event.name}", event_path(@event) %></small>
  <h2>Orders</h2>
  <% if @orders.any? %>
    <small class="text-muted">
      <%= number_to_currency(@orders.sum(&:total_price)) %> across <%= pluralize(@orders.count, "order") %>
      &middot;
      <%= @orders.sum { |o| o.order_items.sum(&:quantity) } %> items
    </small>

    <div class="group items-center">
      <%= link_to "Pickup Sheet", pickup_sheet_event_path(@event), target: "_blank", class: "button" %>
      <small><%= link_to "Export CSV →", export_orders_event_path(@event) %></small>
    </div>
  <% end %>
</div>

<% if @orders.any? %>
  <hr class="divider">

  <table class="responsive-table">
    <thead>
      <tr>
        <th>Customer</th>
        <th>Items</th>
        <th>Qty</th>
        <th>Total</th>
        <th>Fulfillment</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <tr>
          <td data-label="Customer"><%= mail_to order.user.email, order.user.email %></td>
          <td data-label="Items">
            <% order.order_items.each do |item| %>
              <div><%= item.quantity %> &times; <%= item.event_product.name %></div>
            <% end %>
          </td>
          <td data-label="Qty"><%= order.order_items.sum(&:quantity) %></td>
          <td data-label="Total"><%= number_to_currency(order.total_price) %></td>
          <td data-label="Fulfillment">
            <%= order.delivery_address.present? ? "Delivery" : "Pickup" %>
            <% if order.delivery_address.present? %>
              <small class="text-muted"><%= order.delivery_address %></small>
            <% end %>
          </td>
          <td data-label="Notes"><%= order.notes.presence %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty-state">
    <p>No orders yet. Share your shop link so customers can place orders.</p>
  </div>
<% end %>

<% content_for :title, @event.name %>

<%# === Event Header === %>
<div class="stack-sm">
  <div class="group justify-between items-start">
    <div class="stack-sm">
      <div class="group items-center">
        <h2><%= @event.name %></h2>
        <% if @event.draft? %>
          <span class="badge draft">Draft</span>
        <% end %>
      </div>
      <small>
        Orders close <%= nice_date(@event.orders_close_at) %> &middot;
        Pickup <%= pickup_window(@event) %>
      </small>
      <%= render "application/address_line", model: @event %>
      <% if @event.repeat_interval.present? && !@event.no_repeat? %>
        <small>Repeats <%= @event.repeat_interval.humanize %></small>
      <% end %>
    </div>

    <% if current_user == @store.user %>
      <div class="group items-center">
        <% unless @event.past? %>
          <%= link_to "Edit", edit_event_path(@event), class: "button" %>
        <% end %>
        <%= button_to "Reuse", duplicate_event_path(@event),
            method: :post,
            class: "button",
            data: { turbo_confirm: "Duplicate this event? All products and images will be copied to a new draft." } %>
        <% if !@event.past? && (@event.draft? || @event.orders.empty?) %>
          <%= button_to "Delete", event_path(@event),
              method: :delete,
              class: "button",
              data: { turbo_confirm: "Are you sure? This will permanently delete the event." } %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @event.description.present? %>
    <p><%= @event.description %></p>
  <% end %>
</div>

<% if @event.past? %>
  <div class="nudge">
    <small>This is a past event. Details are read-only.</small>
  </div>
<% end %>

<%# === Publish nudge (drafts only) === %>
<% if @event.draft? && current_user == @store.user %>
  <% if @event.publishable? %>
    <div class="nudge">
      <div class="group justify-between items-center">
        <span>Ready to go? Publishing will notify all subscribers.</span>
        <%= button_to "Publish Event", publish_event_path(@event), method: :post,
            class: "button primary",
            data: { turbo_confirm: "Are you sure? This will email all subscribers." } %>
      </div>
    </div>
  <% else %>
    <div class="nudge">
      <strong>Before you can publish:</strong>
      <ul class="stack-sm">
        <% @event.publish_blockers.each do |blocker| %>
          <li><%= blocker %></li>
        <% end %>
      </ul>
      <% if @event.pickup_starts_at.present? && @event.pickup_starts_at <= Time.current %>
        <p><%= link_to "Edit dates", edit_event_path(@event), class: "button" %></p>
      <% end %>
    </div>
  <% end %>
<% end %>

<%# === Orders (published only) === %>
<% if @event.published? %>
  <hr class="divider">

  <div class="stack-sm">
    <div class="group justify-between items-baseline">
      <h3>Orders <% if @orders.any? %><small>(<%= @orders.count %>)</small><% end %></h3>
      <% if @orders.any? %>
        <div class="group">
          <%= link_to "Pickup Sheet", pickup_sheet_event_path(@event), target: "_blank", class: "button" %>
          <%= link_to "Prep List", prep_event_path(@event), target: "_blank", class: "button" %>
          <%= link_to "Export CSV", export_orders_event_path(@event), class: "button" %>
        </div>
      <% end %>
    </div>

    <% if @orders.any? %>
      <small class="text-muted">
        <%= number_to_currency(@orders.sum(&:total_price)) %> across <%= pluralize(@orders.count, "order") %>
        &middot;
        <%= @orders.sum { |o| o.order_items.sum(&:quantity) } %> items
      </small>

      <div class="stack">
        <% @orders.each do |order| %>
          <article class="order-card stack-sm">
            <header class="group justify-between items-baseline">
              <strong><%= mail_to order.user.email, order.user.email %></strong>
              <div class="group-sm items-baseline">
                <strong><%= number_to_currency(order.total_price) %></strong>
                <small class="text-muted" title="<%= order.created_at.strftime('%Y-%m-%d %H:%M') %>"><%= nice_date(order.created_at) %></small>
              </div>
            </header>

            <ul class="order-card-items">
              <% order.order_items.each do |item| %>
                <li><%= item.quantity %> &times; <%= item.event_product.name %></li>
              <% end %>
            </ul>

            <% if order.notes.present? %>
              <div class="order-card-note">
                <strong>Note:</strong> <%= order.notes %>
              </div>
            <% end %>

            <% if order.delivery_address.present? %>
              <div class="order-card-delivery text-muted">
                <small><strong>Delivery:</strong> <%= order.delivery_address %></small>
              </div>
            <% end %>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <p>No orders yet. Share your shop link so customers can place orders.</p>
      </div>
    <% end %>
  </div>
<% end %>

<%# === Products (simplified) === %>
<hr class="divider">

<div class="stack-sm">
  <div class="group justify-between items-baseline">
    <h4>Products <small>(<%= @event.event_products.size %>)</small></h4>
    <% if current_user == @store.user && !@event.past? %>
      <%= link_to "+ Add Product", new_event_event_product_path(@event), class: "button" %>
    <% end %>
  </div>

  <% if @event.event_products.any? %>
    <ul class="product-list stack-sm">
      <% @event.event_products.each do |product| %>
        <li class="product-row group justify-between items-center">
          <div class="group items-center">
            <% if product.image.attached? %>
              <%= image_tag product.image.variant(resize_to_limit: [40, 40], format: :webp), class: "img-thumb" %>
            <% end %>
            <span><strong><%= product.name %></strong></span>
            <small class="text-muted"><%= product.sold %> / <%= product.quantity %></small>
          </div>
          <div class="group-sm items-baseline">
            <span><%= product.price_formatted %></span>
            <% if current_user == @store.user && !@event.past? %>
              <%= link_to "Edit", edit_event_product_path(product), class: "text-muted" %>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="empty-state">
      <p>No products yet. Add at least one product before you can publish this event.</p>
      <% if current_user == @store.user %>
        <p><%= link_to "Add a product", new_event_event_product_path(@event), class: "button primary" %></p>
      <% end %>
    </div>
  <% end %>
</div>

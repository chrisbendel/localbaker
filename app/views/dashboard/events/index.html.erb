<% content_for :title, "#{@store.name} — All Events" %>

<div class="group justify-between items-center">
  <h3>Events</h3>
  <%= link_to "+ New Event", new_dashboard_event_path, class: "button primary" %>
</div>

<%
  active_events = @events.reject(&:past?).reject(&:draft?)
  draft_events = @events.select(&:draft?)
  past_events = @events.select(&:past?)
%>

<div class="stack-lg">
  <%# Active — published, still upcoming. The day-to-day list. %>
  <% if active_events.any? %>
    <div class="stack-sm">
      <h4>Active bakes</h4>
      <ul class="event-list">
        <% active_events.each do |event| %>
          <li class="event-row" id="<%= dom_id(event) %>">
            <%= link_to event.name, event_path(event) %>
            <small class="text-muted">
              <%= event.orders_open? ? "orders close #{nice_date(event.orders_close_at)}" : "orders closed" %> · pickup <%= nice_date(event.pickup_starts_at) %>
            </small>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Drafts — not yet published. %>
  <% if draft_events.any? %>
    <div class="stack-sm">
      <h4>Drafts</h4>
      <ul class="event-list">
        <% draft_events.each do |event| %>
          <li class="event-row" id="<%= dom_id(event) %>">
            <%= link_to event.name, event_path(event) %>
            <small class="text-muted">pickup <%= nice_date(event.pickup_starts_at) %></small>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Past — collapsed; rarely needed day-to-day. %>
  <% if past_events.any? %>
    <details class="stack-sm">
      <summary><strong>Past bakes</strong> <span class="text-muted">(<%= past_events.size %>)</span></summary>
      <ul class="event-list">
        <% past_events.each do |event| %>
          <li class="event-row" id="<%= dom_id(event) %>">
            <%= link_to event.name, event_path(event) %>
            <small class="text-muted">pickup <%= nice_date(event.pickup_starts_at) %></small>
          </li>
        <% end %>
      </ul>
    </details>
  <% end %>

  <% if @events.empty? %>
    <div class="empty-state stack-sm">
      <p>Events are how you sell. Create one to set a pickup date, add products, and start taking orders.</p>
      <%= link_to "Create your first event", new_dashboard_event_path, class: "button primary" %>
    </div>
  <% end %>
</div>

<%# Shared by new + edit. Caller passes `event`, `url`, and `submit_label`;
    form_with picks POST vs PATCH from the record's persisted? state. %>
<%= form_with model: event, url: url, local: true do |form| %>
  <% if event.errors[:base].any? %>
    <div class="panel text-danger stack-sm">
      <p>Please fix the errors below before saving.</p>
      <ul class="stack-sm">
        <% event.errors[:base].each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name, required: true %>
    <%= field_error event, :name %>
  </div>

  <div>
    <%= form.label :description %>
    <%= form.text_area :description %>
  </div>

  <div>
    <%= form.label :pickup_address, "Pickup Location" %>
    <%= form.text_field :pickup_address, placeholder: "e.g. The Climbing Gym, 456 Oak Ave, Portland, OR" %>
    <p class="field-hint">Leave blank to use your store's default address.</p>
  </div>

  <%# The three when-fields, grouped so they read as one block, not a wall. %>
  <fieldset class="field-group stack-sm">
    <legend>Timing</legend>

    <div>
      <%= form.label :orders_close_at, "Orders close" %>
      <%= form.date_field :orders_close_at, required: true, min: Date.current %>
      <%= field_error event, :orders_close_at %>
    </div>

    <div>
      <%= form.label :pickup_starts_at, "Pickup window start" %>
      <%= form.datetime_local_field :pickup_starts_at, required: true, min: Date.current %>
      <%= field_error event, :pickup_starts_at %>
    </div>

    <div>
      <%= form.label :pickup_ends_at, "Pickup window end" %>
      <%= form.datetime_local_field :pickup_ends_at, required: true, min: Date.current %>
      <%= field_error event, :pickup_ends_at %>
    </div>
  </fieldset>

  <div>
    <%= form.label :repeat_interval, "Repeat cadence" %>
    <%= form.select :repeat_interval, Event.repeat_intervals.keys.map { |k| [k.gsub("_", " ").humanize, k] } %>
    <p class="field-hint">On publish, the next bake's draft is created automatically.</p>
  </div>

  <% if current_user.pro? %>
    <div>
      <label class="group-sm items-center">
        <%= form.check_box :delivery_enabled %>
        <span>Allow delivery</span>
      </label>
      <p class="field-hint">Customers can enter a delivery address instead of picking up.</p>
    </div>
  <% else %>
    <div class="nudge">
      <p>Delivery is a Pro feature. <%= link_to "Upgrade to Pro", billing_upgrade_path %> to offer it.</p>
    </div>
  <% end %>

  <%= form.submit submit_label, class: "button primary" %>
<% end %>

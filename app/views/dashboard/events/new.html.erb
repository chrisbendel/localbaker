
<h3>New Event</h3>

<%= form_with model: @event, url: dashboard_events_path, local: true do |form| %>
  <% if @event.errors.any? %>
    <div class="panel text-danger">
      <p>Please fix the errors below before saving.</p>
      <% if @event.errors[:base].any? %>
        <ul class="stack-sm">
          <% @event.errors[:base].each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name, required: true %>
    <% if @event.errors[:name].any? %>
      <p class="field-error"><%= @event.errors[:name].join(", ") %></p>
    <% end %>
  </div>

  <div>
    <%= form.label :description %>
    <%= form.text_area :description %>
  </div>

  <div>
    <%= form.label :pickup_address, "Pickup Location" %>
    <%= form.text_field :pickup_address, placeholder: "e.g. The Climbing Gym, 456 Oak Ave, Portland, OR" %>
    <p class="field-hint">Where customers should pick up their order. Leave blank to use your store's default address.</p>
  </div>

  <% if current_user.pro? %>
    <div>
      <%= form.label :delivery_enabled, "Allow Delivery" %>
      <%= form.check_box :delivery_enabled %>
      <p class="field-hint">Let customers enter a delivery address instead of picking up. Both pickup and delivery can be offered.</p>
    </div>
  <% else %>
    <div class="nudge">
      <p>Delivery is a Pro feature. <%= link_to "Upgrade to Pro", billing_upgrade_path %> to offer delivery on your events.</p>
    </div>
  <% end %>

  <div>
    <%= form.label :orders_close_at, "Orders close at" %>
    <%= form.date_field :orders_close_at, required: true, min: Date.current %>
    <% if @event.errors[:orders_close_at].any? %>
      <p class="field-error"><%= @event.errors[:orders_close_at].join(", ") %></p>
    <% end %>
  </div>

  <div>
    <%= form.label :pickup_starts_at, "Pickup window start" %>
    <%= form.datetime_local_field :pickup_starts_at, required: true, min: Date.current %>
    <% if @event.errors[:pickup_starts_at].any? %>
      <p class="field-error"><%= @event.errors[:pickup_starts_at].join(", ") %></p>
    <% end %>
  </div>

  <div>
    <%= form.label :pickup_ends_at, "Pickup window end" %>
    <%= form.datetime_local_field :pickup_ends_at, required: true, min: Date.current %>
    <p class="field-hint">Set a window customers can arrive during, e.g. 11am – 4pm.</p>
    <% if @event.errors[:pickup_ends_at].any? %>
      <p class="field-error"><%= @event.errors[:pickup_ends_at].join(", ") %></p>
    <% end %>
  </div>

  <div>
    <%= form.label :repeat_interval, "Repeat cadence" %>
    <%= form.select :repeat_interval, Event.repeat_intervals.keys.map { |k| [k.gsub("_", " ").humanize, k] } %>
    <p class="field-hint">When published, a new draft will be created automatically for the next bake.</p>
  </div>

  <div style="margin-top: var(--sp-md);">
    <%= form.submit "Create Event", class: "button primary" %>
  </div>
<% end %>

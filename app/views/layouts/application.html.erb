<!DOCTYPE html>
<html>
<head>
  <title><%= content_for(:title) || "LocalBaker | Find a local bakery near me" %></title>
  <meta name="description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'LocalBaker: Simple pre-orders for home bakeries. Find a local baker near you, order fresh bread, and discover the best local bakery goods in your community.' %>">

  <meta property="og:title" content="<%= content_for(:title) || 'LocalBaker | Find a local bakery near me' %>">
  <meta property="og:description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'LocalBaker: Simple pre-orders for home bakeries. Find a local baker near you, order fresh bread, and discover the best local bakery goods in your community.' %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="LocalBaker">
  <meta property="og:url" content="<%= request.original_url %>">
  <% if content_for?(:og_image) %>
    <meta property="og:image" content="<%= yield(:og_image) %>">
  <% end %>
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="application-name" content="LocalBaker">
  <meta name="mobile-web-app-capable" content="yes">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
  <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

  <link rel="icon" href="/baguette.png" type="image/png">
  <link rel="icon" href="/baguette.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">

  <%# Includes all stylesheet files in app/assets/stylesheets %>
  <%= stylesheet_link_tag :application, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>

<body class="container">

<%= render "application/header" %>

<main>
  <dialog id="flash-dialog">
    <% flash.each do |type, message| %>
      <p class="<%= type %>"><%= message %></p>
    <% end %>
  </dialog>

  <script>
    (() => {
      const d = document.getElementById("flash-dialog");
      if (d && d.children.length > 0) {
        d.show();
        setTimeout(() => d.close(), 3000);
      }
    })();
  </script>

  <%= yield %>
</main>

<footer>
  <div class="group justify-between items-center">
    <span>&copy; <%= Time.current.year %> LocalBaker</span>
    <nav class="group">
      <%= link_to "Home", root_path %>
      <span class="text-muted" aria-hidden="true">&middot;</span>
      <%= link_to "Our Ethos", about_path %>
    </nav>
  </div>
</footer>
</body>
</html>

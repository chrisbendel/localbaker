<% content_for :title, "#{@event.name} — #{@store.name} | Order bread near me" %>

<% og_description = @event.description.present? ? @event.description : "Order bread and baked goods for pick up from #{@store.name}, your local bakery, on #{pickup_datetime(@event.pickup_starts_at)}." %>
<% content_for(:meta_description, og_description) %>

<% if @store.banner_image.attached? %>
  <% content_for(:og_image, url_for(@store.banner_image)) %>
<% else %>
  <% content_for(:og_image, root_url.chomp("/") + "/baguette-solid.png") %>
<% end %>

<div class="stack-lg">
  <header class="stack-sm">
    <div class="group justify-between items-baseline">
      <%= link_to "← #{@store.name}", storefront_path(@store.slug), class: "store-name-link text-muted" %>
    </div>

    <div class="stack-sm">
      <h1 class="font-heading text-xl"><%= @event.name %></h1>

      <% if @event.description.present? %>
        <p class="text-lg"><%= @event.description %></p>
      <% end %>

      <div class="stack-sm">
        <div class="group-sm items-center text-muted">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          <small><%= event_timing_summary(@event) %></small>
        </div>

        <% if @event.address.present? %>
          <div class="group-sm items-center text-muted">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <small><%= link_to @event.address, google_maps_url(@event.address), target: "_blank", rel: "noopener noreferrer" %></small>
          </div>
        <% end %>
      </div>
    </div>
  </header>

  <%# 1. Ordering Context (Always above products) %>
  <div class="stack" id="storefront-order-context">
    <% if @event.orders_closed? %>
      <div class="nudge">
        Orders for this bake have closed.<% if @order&.order_items&.any? %> Your confirmed order is shown below.<% end %>
      </div>
    <% end %>

    <% if authenticated? %>
      <% if @order&.order_items&.any? %>
        <%= render "storefront/order_summary", order: @order, store: @store, event: @event %>
      <% end %>
    <% elsif @event.orders_open? %>
      <div class="panel stack-sm">
        <h3>Ready to order?</h3>
        <p class="text-muted"><small>Sign in with an email link to start your order. No passwords required.</small></p>
        <div>
          <%= link_to "Sign in to order", new_session_path(return_to: request.fullpath), class: "button primary" %>
        </div>
      </div>
    <% end %>
  </div>

  <%# 2. Products (Flex Columns) %>
  <% if @event.orders_open? %>
    <section class="stack">
      <h4>Products</h4>
      <div class="flex-cols-2">
        <% @products.each do |product| %>
          <%= render "storefront/product_card", product: product, store: @store, event: @event %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>

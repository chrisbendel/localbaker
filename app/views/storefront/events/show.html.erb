<% content_for :title, "#{@event.name} — #{@store.name} | Order bread near me" %>

<% og_description = @event.description.present? ? @event.description : "Order bread and baked goods for pick up from #{@store.name}, your local bakery, on #{pickup_datetime(@event.pickup_at)}." %>
<% content_for(:meta_description, og_description) %>

<% if @store.banner_image.attached? %>
  <% content_for(:og_image, url_for(@store.banner_image)) %>
<% else %>
  <% content_for(:og_image, root_url.chomp("/") + "/baguette-solid.png") %>
<% end %>

<nav class="breadcrumbs">
  <%= link_to @store.name, storefront_path(@store.slug) %>
  <span class="sep"></span>
  <%= @event.name %>
</nav>

<div class="stack">
  <%= render "storefront/event_details", event: @event %>

  <div class="panel grid grid-cols-2">
    <div class="stack-sm">
      <span class="text-sm text-muted font-bold uppercase">Pickup</span>
      <span class="text-lg"><%= pickup_datetime(@event.pickup_at) %></span>
    </div>
    <div class="stack-sm">
      <span class="text-sm text-muted font-bold uppercase">Order By</span>
      <span class="text-lg <%= @event.orders_open? ? "text-success" : "text-danger" %>"><%= nice_date(@event.orders_close_at) %></span>
    </div>
  </div>

  <% if @event.orders_closed? %>
    <div class="nudge">
      Orders for this bake have closed.<% if @order&.order_items&.any? %> Your confirmed order is shown below.<% end %>
    </div>
  <% end %>

  <% if @event.orders_open? %>
    <h2 class="section-title">Products</h2>
    <div class="grid grid-sidebar">
      <div class="stack-sm">
        <% @products.each do |product| %>
          <%= render "storefront/product_card", product: product, store: @store, event: @event %>
        <% end %>
      </div>
      <aside>
        <% if authenticated? %>
          <%= render "storefront/order_summary", order: @order, store: @store, event: @event %>
        <% else %>
          <div class="panel stack-sm">
            <h3 class="font-bold">Ready to order?</h3>
            <p class="text-sm text-muted">Sign in with an email link to start your order. No passwords required.</p>
            <div>
              <%= link_to "Sign in to order", new_session_path(return_to: request.fullpath), class: "button primary" %>
            </div>
          </div>
        <% end %>
      </aside>
    </div>
  <% else %>
    <section class="stack-sm">
      <h2 class="section-title">Products</h2>
      <div class="stack-sm">
        <% @products.each do |product| %>
          <%= render "storefront/product_card", product: product, store: @store, event: @event %>
        <% end %>
      </div>
    </section>
    <% if @order&.order_items&.any? %>
      <%= render "storefront/order_summary", order: @order, store: @store, event: @event %>
    <% end %>
  <% end %>
</div>

<%= render "storefront/store_hero", store: @store, show_back_link: true %>

<div class="stack">
  <%= render "storefront/event_details", event: @event %>

  <div class="grid grid-cols-1 md:grid-cols-2" style="align-items: start; gap: 2rem;">
    <!-- Products Column -->
    <section class="stack">
      <h2 class="section-title">Products Available</h2>
      <div class="grid grid-cols-1">
        <% @products.each do |product| %>
          <%= render "storefront/product_card", product: product, store: @store, event: @event %>
        <% end %>
      </div>
    </section>

    <!-- Order Summary Column -->
    <aside>
      <%= render "storefront/order_summary", order: @order, store: @store %>
    </aside>
  </div>
</div>

<style>
  @media (min-width: 768px) {
    .md\:grid-cols-2 { grid-template-columns: 1fr 350px; }
  }
</style>

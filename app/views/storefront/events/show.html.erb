<% content_for :title, "#{@event.name} — #{@store.name}" %>

<% content_for :head do %>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="LocalBaker">
  <meta property="og:title" content="<%= "#{@event.name} — #{@store.name}" %>">
  <% og_description = @event.description.present? ? @event.description : "Pick up from #{@store.name} on #{pickup_datetime(@event.pickup_at)}." %>
  <meta property="og:description" content="<%= og_description %>">
  <meta property="og:url" content="<%= request.url %>">
  <% if @store.banner_image.attached? %>
    <meta property="og:image" content="<%= url_for(@store.banner_image) %>">
  <% else %>
    <meta property="og:image" content="<%= root_url.chomp("/") + "/baguette-solid.png" %>">
  <% end %>
<% end %>

<nav class="breadcrumbs">
  <%= link_to @store.name, storefront_path(@store.slug) %>
  <span class="sep"></span>
  <%= @event.name %>
</nav>

<div class="stack">
  <%= render "storefront/event_details", event: @event %>

  <% if @event.orders_closed? %>
    <div class="nudge">
      Orders for this bake have closed.<% if @order&.order_items&.any? %> Your confirmed order is shown below.<% end %>
    </div>
  <% end %>

  <% if @event.orders_open? %>
    <div class="group justify-between items-baseline">
      <h2 class="section-title">Products</h2>
      <span class="text-sm text-success">Order by <%= nice_date(@event.orders_close_at) %></span>
    </div>
    <div class="grid grid-sidebar">
      <div class="stack-sm">
        <% @products.each do |product| %>
          <%= render "storefront/product_card", product: product, store: @store, event: @event %>
        <% end %>
      </div>
      <aside>
        <%= render "storefront/order_summary", order: @order, store: @store, event: @event %>
      </aside>
    </div>
  <% else %>
    <section class="stack-sm">
      <h2 class="section-title">Products</h2>
      <div class="stack-sm">
        <% @products.each do |product| %>
          <%= render "storefront/product_card", product: product, store: @store, event: @event %>
        <% end %>
      </div>
    </section>
    <% if @order&.order_items&.any? %>
      <%= render "storefront/order_summary", order: @order, store: @store, event: @event %>
    <% end %>
  <% end %>
</div>

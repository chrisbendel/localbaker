<% ordered ||= false %>
<%= link_to storefront_event_path(event.store.slug, event), class: "card block #{"sold-out" if event.past?}" do %>
  <div class="stack-sm">
    <div class="group justify-between items-start">
      <div class="stack-sm">
        <strong><%= event.pickup_at.strftime("%A, %b %-d") %></strong>
        <h3><%= event.name %></h3>
      </div>
      <% if event.past? %>
        <span class="badge closed">Closed</span>
      <% elsif ordered %>
        <span class="badge ordered">Ordered ✓</span>
      <% end %>
    </div>

    <div class="group justify-between items-baseline">
      <p>Pickup: <strong><%= event.pickup_at.strftime("%l:%M %p") %></strong></p>
      <% unless event.past? %>
        <small>Closes <%= fuzzy_date(event.orders_close_at) %></small>
      <% end %>
    </div>

    <% if (products_count = event.event_products.size) > 0 %>
      <small class="text-muted"><%= pluralize(products_count, "product") %> available</small>
    <% end %>
  </div>
<% end %>

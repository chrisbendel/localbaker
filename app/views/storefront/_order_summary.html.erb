<section class="panel stack-sm">
  <div class="group justify-between items-baseline">
    <strong>
      <%= order.confirmed? ? "Order confirmed" : "Your order" %>
    </strong>
    <strong><%= number_to_currency(order.total_price) %></strong>
  </div>

  <div class="order-items">
    <% order.order_items.includes(:event_product).each do |item| %>
      <div class="group justify-between items-center">
        <span><%= item.event_product.name %></span>
        <span class="group items-center">
          <small>×<%= item.quantity %></small>
          <% if event.orders_open? && !order.confirmed? %>
            <%= button_to storefront_order_item_path(store.slug, item),
                method: :delete,
                class: "button-link text-muted",
                form: { data: { turbo_confirm: "Remove #{item.event_product.name} from your order?" } },
                aria: { label: "Remove #{item.event_product.name}" } do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="3 6 5 6 21 6"/>
                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                <path d="M10 11v6"/><path d="M14 11v6"/>
                <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
              </svg>
            <% end %>
          <% end %>
        </span>
      </div>
    <% end %>
  </div>

  <div class="order-summary-pickup">
    <p><small>Pickup <%= fuzzy_date(event.pickup_at) %> &middot; <%= pickup_datetime(event.pickup_at) %></small></p>
  </div>

  <% if event.orders_open? %>
    <% if order.confirmed? %>
        <div class="group">
          <%= link_to "Add to Google Calendar", google_calendar_url(event), class: "button secondary", target: "_blank", rel: "noopener noreferrer" %>
          <%= link_to "Download .ics", calendar_storefront_event_path(store.slug, event), class: "button secondary" %>
        </div>
        <%= button_to "Edit Order", unconfirm_storefront_event_path(store.slug, event), method: :post, class: "button-link text-muted" %>

        <% if store.venmo_handle.present? || store.paypal_url.present? %>
          <div class="stack-sm order-summary-payment">
            <h4>Payment</h4>
            <div class="group">
              <% if store.venmo_handle.present? %>
                <%= link_to store.venmo_url, target: "_blank", rel: "noopener noreferrer" do %>
                  Venmo (@<%= store.venmo_handle %>)
                <% end %>
              <% end %>

              <% if store.paypal_url.present? %>
                <%= link_to store.paypal_url, target: "_blank", rel: "noopener noreferrer" do %>
                  PayPal
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= form_with url: confirm_storefront_event_path(store.slug, event), method: :post, local: true do |f| %>
        <% if event.delivery_enabled? %>
          <div class="stack-sm">
            <%= f.label :delivery_address, "Delivery Address (Optional)" %>
            <%= f.text_field :delivery_address,
                placeholder: "Street address, city, state, zip",
                value: order.delivery_address %>
            <small>Leave blank for pickup. Enter an address for delivery.</small>
          </div>
        <% end %>
        <%= f.submit "Complete Order", class: "button primary full" %>
      <% end %>
    <% end %>
  <% end %>
</section>

<section class="stack">
  <h2 class="section-title">Your Order</h2>

  <% if order&.order_items&.any? %>
    <table class="responsive-table">
      <tbody>
        <% order.order_items.includes(:event_product).each do |item| %>
          <tr>
            <td data-label="Product"><strong><%= item.event_product.name %></strong></td>
            <td data-label="Quantity">
              <% if event.orders_open? %>
                <div class="group items-center">
                  <%= button_to "−", storefront_order_item_path(store.slug, item),
                      method: :patch,
                      params: { order_item: { quantity: item.quantity - 1 } },
                      class: "button" %>
                  <span><%= item.quantity %></span>
                  <%= button_to "+", storefront_order_item_path(store.slug, item),
                      method: :patch,
                      params: { order_item: { quantity: item.quantity + 1 } },
                      class: "button" %>
                </div>
              <% else %>
                <span><%= item.quantity %></span>
              <% end %>
            </td>
            <td data-label="Price"><%= item.event_product.price_formatted %></td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="2">Total</td>
          <td><%= number_to_currency(order.total_price) %></td>
        </tr>
      </tfoot>
    </table>

    <% if event.orders_closed? %>
      <div class="order-confirmed">
        Your order is locked in. See you at pickup on
        <strong><%= pickup_datetime(event.pickup_at) %></strong>!
      </div>
    <% else %>
      <div class="order-confirmed">
        Your order is saved. Bring this confirmation to pickup on
        <strong><%= pickup_datetime(event.pickup_at) %></strong>.
      </div>
    <% end %>
  <% else %>
    <p class="text-muted">No items yet — add something from the list.</p>
  <% end %>
</section>

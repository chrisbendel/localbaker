<div class="card stack-sm">
  <% if product.image.attached? %>
    <%= image_tag product.image.variant(resize_to_limit: [600, 400], format: :webp), class: "img-product" %>
  <% end %>
  <div class="group justify-between items-baseline">
    <h3><%= product.name %></h3>
    <span class="badge <%= product.available? ? 'available' : 'sold-out' %>">
      <%= product.available? ? "#{product.remaining} left" : "Sold Out" %>
    </span>
  </div>

  <div class="group justify-between items-center">
    <span class="text-lg"><%= product.price_formatted %></span>

    <% if event.orders_open? && product.available? %>
      <% if authenticated? %>
        <%= form_with url: storefront_event_order_items_path(store.slug, event, event_product_id: product.id), method: :post do %>
          <button class="primary">Add to Order</button>
        <% end %>
      <% else %>
        <%= link_to "Sign in to order", new_session_path(return_to: request.fullpath), class: "button primary" %>
      <% end %>
    <% elsif !event.orders_open? %>
      <button disabled>Orders Closed</button>
    <% else %>
      <button disabled>Unavailable</button>
    <% end %>
  </div>
</div>

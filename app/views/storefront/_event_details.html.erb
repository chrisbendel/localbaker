<section class="card-accent stack-sm">
  <h2><%= event.name %></h2>

  <% if event.description.present? %>
    <p><%= event.description %></p>
  <% end %>

  <div class="stack-sm text-muted text-sm">
    <span><strong>Pickup:</strong> <%= pickup_datetime(event.pickup_at) %></span>
    <% if event.orders_open? %>
      <span class="text-success"><strong>Order by</strong> <%= nice_date(event.orders_close_at) %></span>
    <% else %>
      <span><strong>Orders closed</strong> <%= nice_date(event.orders_close_at) %></span>
    <% end %>
  </div>

  <%= render "application/address_line", model: event, show_full: true %>
</section>

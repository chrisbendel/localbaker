<section class="card-accent stack-sm">
  <div class="group justify-between items-center">
    <h2><%= event.name %></h2>
    <% if event.orders_open? %>
      <span class="badge available">Open for Orders</span>
    <% elsif event.orders_closed? %>
      <span class="badge closed">Orders Closed</span>
    <% else %>
      <span class="badge draft">Draft</span>
    <% end %>
  </div>

  <% if event.description.present? %>
    <p><%= event.description %></p>
  <% end %>

  <div class="group-lg text-muted text-sm">
    <span><strong>Pickup:</strong> <%= pickup_datetime(event.pickup_at) %></span>
    <span><strong>Orders close:</strong> <%= nice_date(event.orders_close_at) %></span>
  </div>

  <%= render "application/address_line", model: event, show_full: true %>
</section>

<a href="<%= storefront_event_path(store.slug, event) %>" class="card stack" style="text-decoration: none; color: inherit;">
  <div class="group justify-between items-center">
    <h3><%= event.name %></h3>
  </div>

  <div class="group-lg text-muted text-sm">
    <span>Pickup: <%= nice_date(event.pickup_at) %></span>
    <span>Orders close: <%= nice_date(event.orders_close_at) %></span>
  </div>
</a>

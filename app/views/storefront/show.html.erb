<%= content_for(:title, "#{@store.name} | Local bakery near me") %>

<% content_for(:meta_description, @store.description.presence || "Order fresh bread and baked goods from #{@store.name}, a local bakery near you. Pre-order and pick up from this neighborhood home baker on LocalBaker.") %>
<% if @store.banner_image.attached? %>
  <% content_for(:og_image, url_for(@store.banner_image)) %>
<% else %>
  <% content_for(:og_image, root_url.chomp("/") + "/baguette-solid.png") %>
<% end %>

<header class="stack-sm">
  <% if @store.banner_image.attached? %>
    <%= image_tag @store.banner_image.variant(resize_to_limit: [1200, 800], format: :webp), class: "img-banner" %>
  <% end %>
  <div class="group justify-between items-center">
  <h1><%= @store.name %></h1>
    <% if @notification.present? %>
      <%= button_to storefront_notification_path(@store.slug), method: :delete, class: "button secondary", title: "Unsubscribe from email updates" do %>
        Unsubscribe
      <% end %>
    <% else %>
      <%= button_to storefront_notification_path(@store.slug), method: :post, class: "button secondary", title: "Subscribe to email updates" do %>
        Subscribe
      <% end %>
    <% end %>
  </div>
  <%= render "application/address_line", model: @store %>
  <% if @store.description.present? %>
    <p class="text-muted"><%= @store.description %></p>
  <% end %>
</header>

<section class="stack">
  <h2 class="section-title">Upcoming Bakes</h2>

  <div class="grid grid-cols-2">
    <% @events.each do |event| %>
      <%= render "storefront/event_list_item", event: event, store: @store %>
    <% end %>
  </div>
  
  <% if @events.empty? %>
    <p class="text-muted">No upcoming events scheduled right now. Check back soon!</p>
  <% end %>
</section>
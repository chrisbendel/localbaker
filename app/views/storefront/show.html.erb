<%= content_for(:title, @store.name) %>

<% content_for :head do %>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="LocalBaker">
  <meta property="og:title" content="<%= @store.name %>">
  <meta property="og:description" content="Order fresh baked goods from <%= @store.name %> on LocalBaker.">
  <meta property="og:url" content="<%= request.url %>">
  <% if @store.banner_image.attached? %>
    <meta property="og:image" content="<%= url_for(@store.banner_image) %>">
  <% else %>
    <meta property="og:image" content="<%= root_url.chomp("/") + "/baguette-solid.png" %>">
  <% end %>
<% end %>

<%= render "storefront/store_hero", store: @store %>

<section class="stack">
  <div class="group justify-between items-center">
    <h2 class="section-title">Upcoming Bakes</h2>
    
    <% if @notification.present? %>
      <%= button_to storefront_notification_path(@store.slug), method: :delete, class: "button small secondary", title: "Unsubscribe from email updates" do %>
        Unsubscribe
      <% end %>
    <% else %>
      <%= button_to storefront_notification_path(@store.slug), method: :post, class: "button small secondary", title: "Subscribe to email updates" do %>
        Subscribe
      <% end %>
    <% end %>
  </div>

  <div class="grid grid-cols-2">
    <% @events.each do |event| %>
      <%= render "storefront/event_list_item", event: event, store: @store %>
    <% end %>
  </div>
  
  <% if @events.empty? %>
    <p class="text-muted">No upcoming events scheduled right now. Check back soon!</p>
  <% end %>
</section>
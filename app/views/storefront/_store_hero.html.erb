<header class="stack" style="margin-bottom: 2rem;">
  <div class="group justify-between items-baseline">
    <h1><%= store.name %></h1>
    <% if local_assigns[:show_back_link] %>
      <%= link_to "Back to Store", storefront_path(store.slug), class: "text-muted" %>
    <% end %>
  </div>
  <p class="text-muted"><%= store.description %></p>
</header>

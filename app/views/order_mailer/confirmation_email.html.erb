<h1>Order confirmed: <%= @event.name %></h1>

<p>Hi <%= @order.user.email %>,</p>

<p>Your order for <strong><%= @store.name %></strong> has been confirmed!</p>

<div style="background: #f9f9f9; padding: 15px; border: 1px solid #ddd; margin: 20px 0;">
  <h3>Pickup Details</h3>
  <p>
    <strong>When:</strong> <%= @event.pickup_at.strftime("%A, %b %-d at %-I:%M%P") %><br>
    <strong>Where:</strong> <%= @event.effective_pickup_address %>
  </p>
</div>

<h3>Your Order Summary</h3>
<ul>
  <% @order.order_items.includes(:event_product).each do |item| %>
    <li><%= item.quantity %> × <%= item.event_product.name %></li>
  <% end %>
</ul>

<p>Total: <%= number_to_currency(@order.total_price) %></p>

<% if @store.venmo_handle.present? || @store.paypal_url.present? %>
  <div style="background: #eef1ec; padding: 15px; border: 1px solid #bfcbbc; margin: 20px 0;">
    <h3>Payment Options</h3>
    <p>LocalBaker handles orders, but payments happen directly between you and the baker.</p>
    <% if @store.venmo_handle.present? %>
      <p><strong>Venmo:</strong> <%= link_to @store.venmo_handle, @store.venmo_url %></p>
    <% end %>
    <% if @store.paypal_url.present? %>
      <p><strong>PayPal:</strong> <%= link_to "PayPal.me Link", @store.paypal_url %></p>
    <% end %>
  </div>
<% end %>

<p>
  <%= link_to "View your orders", orders_url %>
</p>

<p>
  Thanks for supporting a local baker!<br>
  — The LocalBaker Team
</p>

<% content_for :title, "Notifications" %>

<div class="stack">
  <div class="group justify-between items-center">
    <h3>Notifications</h3>
  </div>

  <% if @notifications.any? %>
    <ul class="product-list stack-sm">
      <% @notifications.each do |notification| %>
        <li class="product-row group justify-between items-center">
          <div>
            <strong><%= notification.store.name %></strong>
            <small class="text-muted">New event notifications</small>
          </div>
          <%= button_to "Unsubscribe", settings_notification_path(notification), method: :delete, class: "button-link text-muted" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="empty-state">
      <p>You're not subscribed to any bakeries.</p>
      <p>Follow a bakery to get notified when they post a new event.</p>
    </div>
  <% end %>
</div>

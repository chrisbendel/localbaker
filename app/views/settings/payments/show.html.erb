<% content_for :title, "Payment Options — Settings" %>

<div class="stack">
  <div class="group justify-between items-center">
    <h3>Payment Options</h3>
  </div>

  <p class="text-muted text-sm">Help customers find your preferred payment methods. LocalBaker handles orders, but payments happen directly between you and your customers.</p>

  <%= form_with model: @store, url: settings_payments_path do |f| %>
    <div class="group">
      <div class="stack-sm">
        <%= f.label :venmo_handle, "Venmo Handle" %>
        <%= f.text_field :venmo_handle, placeholder: "@yourhandle" %>
      </div>

      <div class="stack-sm">
        <%= f.label :paypal_url, "PayPal.me Link" %>
        <%= f.text_field :paypal_url, placeholder: "https://paypal.me/yourname" %>
      </div>
    </div>

    <div class="stack">
      <%= f.submit "Save Changes", class: "button primary" %>
    </div>
  <% end %>
</div>

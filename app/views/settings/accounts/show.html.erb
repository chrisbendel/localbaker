<% content_for :title, "Account Settings" %>

<div class="stack">
  <div class="group justify-between items-center">
    <h3>Account Settings</h3>
  </div>

  <%= form_with model: current_user, url: settings_account_path do |f| %>
    <div>
      <%= f.label :name %>
      <%= f.text_field :name %>
    </div>

    <div>
      <%= f.label :email %>
      <%= f.email_field :email, readonly: true, class: "bg-subtle" %>
      <p class="field-hint">Your login email. Contact support if you need to update this.</p>
    </div>

    <div>
      <%= f.label :address %>
      <%= f.text_field :address, placeholder: "123 Main St, Burlington, VT 05401" %>
      <p class="field-hint">Used to check delivery availability from local bakers.</p>
    </div>

    <div class="group">
      <%= f.submit "Save Changes", class: "button primary" %>
    </div>
  <% end %>

  <hr class="divider">

  <div class="stack-sm">
    <div class="group justify-between items-baseline">
      <strong>Plan</strong>
      <% if current_user.pro? %>
        <span class="badge">Pro</span>
      <% else %>
        <span class="badge secondary">Free</span>
      <% end %>
    </div>
    <div class="group">
      <% if current_user.pro? %>
        <%= button_to "Manage subscription", billing_portal_path, method: :post, class: "button secondary", data: { turbo: false } %>
      <% else %>
        <%= link_to "Upgrade to Pro", billing_upgrade_path, class: "button secondary" %>
      <% end %>
    </div>
  </div>

  <% if !current_user.store&.persisted? %>
    <hr class="divider">
    <div class="card stack-sm">
      <strong>Are you a baker?</strong>
      <p>Create a storefront to start taking pre-orders for your next bake.</p>
      <div class="group">
        <%= link_to "Create your store", new_store_path, class: "button" %>
      </div>
    </div>
  <% end %>

  <hr class="divider">

  <div class="group justify-between items-center">
    <small class="text-muted">Signed in as <%= current_user.email %></small>
    <%= button_to "Sign out", session_path, method: :delete, class: "button secondary" %>
  </div>
</div>

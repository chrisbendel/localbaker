<% content_for :title, "Account Settings — Settings" %>

<div class="stack">
  <div class="group justify-between items-center">
    <h3>Account Settings</h3>
  </div>

  <%= form_with model: current_user, url: settings_account_path do |f| %>
    <div>
      <%= f.label :name %>
      <%= f.text_field :name %>
    </div>

    <div>
      <%= f.label :email %>
      <%= f.email_field :email, readonly: true, class: "bg-subtle" %>
      <p class="field-hint">Your login email. Contact support if you need to update this.</p>
    </div>

    <div>
      <%= f.submit "Save Changes", class: "button primary" %>
    </div>
  <% end %>

  <% if current_user.pro? %>
    <hr class="divider">
    <div class="card stack-sm">
      <p class="font-bold">Pro Subscription</p>
      <p class="text-sm text-muted">You're on the Pro plan. Manage your billing, update payment details, or cancel from the billing portal.</p>
      <div class="group">
        <%= button_to "Manage Subscription", billing_portal_path, method: :post, class: "button", data: { turbo: false } %>
      </div>
    </div>
  <% end %>

  <% if !current_user.store&.persisted? %>
    <hr class="divider">
    <div class="card stack-sm">
      <p class="font-bold">Are you a baker?</p>
      <p class="text-sm text-muted">Create a storefront to start taking pre-orders for your next bake.</p>
      <div class="group">
        <%= link_to "Create your store", new_store_path, class: "button" %>
      </div>
    </div>
  <% end %>

  <% if (store = current_user.store)&.persisted? %>
    <hr class="divider">
    <div class="card stack-sm">
      <p class="font-bold text-danger">Delete Store</p>
      <p class="text-sm text-muted">Permanently remove your storefront and all its data. This cannot be undone.</p>
      <div class="group">
        <%= button_to "Delete Store", store_path(store), method: :delete, class: "button danger", 
            data: { turbo_confirm: "Are you absolutely sure? This will delete your store and all its data." } %>
      </div>
    </div>
  <% end %>
</div>

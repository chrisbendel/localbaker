<% content_for :title, "Your Orders" %>

<% if @orders.any? %>
  <section class="stack">
    <h3>Your Orders</h3>
    <div class="stack-sm">
      <% @orders.each do |order| %>
        <%= link_to shop_event_path(order.event.store.slug, order.event), class: "card" do %>
          <div class="group justify-between items-baseline">
            <strong><%= order.event.store.name %></strong>
            <small><%= number_to_currency(order.total_price) %></small>
          </div>
          <p><small><%= order.event.name %> &middot; Pickup <%= nice_date(order.event.pickup_starts_at) %></small></p>
        <% end %>
      <% end %>
    </div>
  </section>
<% else %>
  <div class="empty-state stack-sm">
    <p>You don't have any orders yet.</p>
    <p>Visit a baker's shop to place an order.</p>
  </div>
<% end %>

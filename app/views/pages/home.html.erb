<% content_for :title, "LocalBaker — A simple shop for home bakers" %>
<% content_for :meta_description, "LocalBaker is a simple shop for home bakers. Post a bake, share a link, customers claim loaves. No app. No password." %>

<div class="stack-lg">
  <div class="stack">
    <h1>A simple shop for home bakers.</h1>
    <p>No inventory system. No app to install. No password for customers. No subscription tiers full of features you won't use.</p>
    <p><%= link_to "Read about LocalBaker", about_path %>.</p>
  </div>

  <hr class="divider">

  <div class="stack">
    <h2>For customers</h2>
    <p>Find a baker near you. Click the link, pick a loaf, pick it up.</p>
    <div class="group">
      <%= link_to "Find a baker", explore_path, class: "button primary" %>
    </div>
  </div>

  <hr class="divider">

  <div class="stack">
    <h2>For bakers</h2>
    <p>Post what you're baking. Share a link. Get a list of who ordered what.</p>
    <div class="group">
      <% if authenticated? && current_user.store&.persisted? %>
        <%= link_to "Manage your shop", dashboard_path, class: "button primary" %>
      <% elsif authenticated? %>
        <%= link_to "Open a shop", new_dashboard_store_path, class: "button primary" %>
      <% else %>
        <%= link_to "Open a shop", new_session_path, class: "button primary" %>
      <% end %>
    </div>
  </div>
</div>

#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# Restore the database if it does not exist and R2 credentials are set
if [ ! -f /data/production.sqlite3 ] && [ -n "$CLOUDFLARE_R2_ACCESS_KEY_ID" ]; then
    echo "Restoring database from Litestream..."
    litestream restore -v -config /etc/litestream.yml /data/production.sqlite3
fi

# If running the rails server then create or migrate existing database
if [ "${1}" == "litestream" ] && [ "${2}" == "replicate" ]; then
  ./bin/rails db:prepare
fi

exec "${@}"
